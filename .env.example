# ─────────────────────────────────────────────
#  LogicAudit – Environment Variable Template
#  Copy this file to .env and fill in your keys
# ─────────────────────────────────────────────

# --- LLM Provider ---
# Choose your provider: "openai" (default) or "gemini"
LLM_PROVIDER=openai

# --- OpenAI (if LLM_PROVIDER=openai) ---
OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o

# --- Google Gemini (if LLM_PROVIDER=gemini) ---
# GEMINI_API_KEY=AIza...
# GEMINI_MODEL=gemini-1.5-pro

# --- libclang Override ---
# Optional: Set this if libclang is in a non-standard path
# CLANG_LIBRARY_PATH=/usr/lib/llvm-14/lib/libclang.so
